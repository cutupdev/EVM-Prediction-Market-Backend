{
  "name": "evm-prediction-market-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node.js TypeScript backend for EVM prediction markets: chain integration, REST/WebSocket API, orderbook, PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
