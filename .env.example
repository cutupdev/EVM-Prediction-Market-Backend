# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prediction_market?schema=public

# EVM — JSON-RPC (Alchemy, Infura, public RPC, etc.)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
CHAIN_ID=11155111

# Optional: hex private key for server-signed txs (relayer, indexing writes). Leave empty for read-only.
OPERATOR_PRIVATE_KEY=

# Core prediction market contract (deployed on CHAIN_ID)
PREDICTION_MARKET_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: collateral ERC20 for the market (USDC, etc.)
COLLATERAL_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# CORS — comma-separated origins for browser UI
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=info

# Order signing (EIP-712) — domain for typed data; must match frontend
EIP712_NAME=PredictionMarketOrders
EIP712_VERSION=1
EIP712_CHAIN_ID=11155111
EIP712_VERIFYING_CONTRACT=0x0000000000000000000000000000000000000000
